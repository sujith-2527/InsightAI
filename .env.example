# Environment Configuration Example
# Copy this file to .env and configure for your needs

# Backend Configuration
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8080
DEBUG_MODE=true

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:8080"]

# Data Configuration
DATA_FILE_PATH=./Backend/cars.csv
MAX_RESULTS=1000

# Server Configuration
WORKERS=1
RELOAD_ON_CHANGE=true

# Logging
LOG_LEVEL=INFO
